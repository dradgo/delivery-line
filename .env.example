# Copy this file to .env and fill in values. Do NOT commit .env (it is in .gitignore per story 1.1 AC6).

# Linear API key for ticket intake — get one at https://linear.app/settings/api
LINEAR_API_KEY=

# GitHub PAT for PR linkage — needs `repo` scope; get one at https://github.com/settings/tokens
GITHUB_TOKEN=

# Base directory for runtime state — defaults to ./deliveryline-data if unset
DELIVERYLINE_HOME=

# Local PostgreSQL password for Docker Compose and Spring Boot service discovery
POSTGRES_PASSWORD=deliveryline

# Override if 5432 is in use on host (story 1.2)
POSTGRES_HOST_PORT=5432

# Reserved for story 1.2 / 3.7 — additional Docker Compose port overrides:
# ELASTIC_HOST_PORT
# LOGSTASH_HOST_PORT
# KIBANA_HOST_PORT
# PROMETHEUS_HOST_PORT
# GRAFANA_HOST_PORT
