{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deliveryline.local/runner-contracts/runner-result.v1.schema.json",
  "title": "DeliveryLine Runner Result v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "workflowRunId",
    "runnerExecutionId",
    "artifactReferences",
    "normalizedOutput",
    "checksum",
    "classification",
    "failureCategory"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "workflowRunId": {
      "type": "string",
      "pattern": "^run_[A-Za-z0-9_-]{4,64}$"
    },
    "runnerExecutionId": {
      "type": "string",
      "pattern": "^rex_[A-Za-z0-9_-]{4,64}$"
    },
    "artifactReferences": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "$ref": "#/$defs/specArtifact"
          },
          {
            "$ref": "#/$defs/implementationPlanArtifact"
          },
          {
            "$ref": "#/$defs/prOutputArtifact"
          }
        ]
      }
    },
    "normalizedOutput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "outcome"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "outcome": {
          "type": "string",
          "enum": [
            "success",
            "failure"
          ]
        }
      }
    },
    "rawOutputReference": {
      "type": "string",
      "minLength": 1
    },
    "checksum": {
      "$ref": "#/$defs/checksum"
    },
    "classification": {
      "type": "string",
      "enum": [
        "local-only",
        "shareable-redacted",
        "shareable-full",
        "derived-public-safe"
      ]
    },
    "failureCategory": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "enum": [
            "runner_timeout",
            "runner_crash",
            "runner_contract_violation",
            "runner_non_zero_exit",
            "runner_late_result",
            "runner_duplicate_result",
            "runner_malformed_output"
          ]
        }
      ]
    }
  },
  "$defs": {
    "baseArtifact": {
      "type": "object",
      "required": [
        "artifactId",
        "artifactType"
      ],
      "properties": {
        "artifactId": {
          "type": "string",
          "pattern": "^art_[A-Za-z0-9_-]{4,64}$"
        },
        "artifactType": {
          "type": "string",
          "enum": [
            "spec",
            "implementationPlan",
            "prOutput"
          ]
        }
      }
    },
    "checksum": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "hexDigest"
      ],
      "properties": {
        "algorithm": {
          "type": "string",
          "enum": [
            "SHA-256"
          ]
        },
        "hexDigest": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        }
      }
    },
    "specArtifact": {
      "unevaluatedProperties": false,
      "allOf": [
        {
          "$ref": "#/$defs/baseArtifact"
        },
        {
          "type": "object",
          "required": [
            "contentReference"
          ],
          "properties": {
            "artifactType": {
              "const": "spec"
            },
            "contentReference": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "implementationPlanArtifact": {
      "unevaluatedProperties": false,
      "allOf": [
        {
          "$ref": "#/$defs/baseArtifact"
        },
        {
          "type": "object",
          "required": [
            "steps",
            "contextReferences"
          ],
          "properties": {
            "artifactType": {
              "const": "implementationPlan"
            },
            "steps": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "contextReferences": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      ]
    },
    "prOutputArtifact": {
      "unevaluatedProperties": false,
      "allOf": [
        {
          "$ref": "#/$defs/baseArtifact"
        },
        {
          "type": "object",
          "required": [
            "branch",
            "commitSha",
            "prReference",
            "diffReference"
          ],
          "properties": {
            "artifactType": {
              "const": "prOutput"
            },
            "branch": {
              "type": "string",
              "minLength": 1
            },
            "commitSha": {
              "type": "string",
              "pattern": "^[a-fA-F0-9]{7,40}$"
            },
            "prReference": {
              "type": "string",
              "minLength": 1
            },
            "diffReference": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    }
  }
}
